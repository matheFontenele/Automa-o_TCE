# --- Ambiente Virtual e Executáveis ---
# Ignora ambientes virtuais, pastas de Python portátil e instaladores
venv/
.venv/
env/
Python/
*.exe

# --- Cache e compilados de Python ---
__pycache__/
*.py[cod]
*$py.class

# --- Dados Gerados ---
# Ignora a pasta de dados e arquivos de resultados
data/
*.csv
*.json
# O "!" inverte a regra: mantém o município.json que é essencial para o script
!municipios.json

# --- Arquivos de Sistema e IDE ---
.vscode/
.idea/
.DS_Store
Thumbs.db
.env

# --- Logs ---
*.log

# --- Arquivos temporários criados pelo seu instalador ---
python_installer.exe